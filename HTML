function setupAutocompleteRiwayat() {
    let saranRiwayat = [];
    dbRiwayat.forEach(row => {
        if (row[1]) saranRiwayat.push(row[1]);
        try {
            const formData = JSON.parse(row[5]);
            if (formData.listPegawai) {
                formData.listPegawai.forEach(p => saranRiwayat.push(p.nama));
            }
        } catch (e) {}
    });
    saranRiwayat = [...new Set(saranRiwayat)];
    $("#customSearchBoxRiwayat").autocomplete({
        source: function(request, response) {
            let matcher = new RegExp($.ui.autocomplete.escapeRegex(request.term), "i");
            response($.grep(saranRiwayat, function(item) {
                return matcher.test(item);
            }).slice(0, 10));
        },
        minLength: 1,
        select: function(event, ui) {
            $(this).val(ui.item.value);

            if (dataTableRiwayatInstance) dataTableRiwayatInstance.search(ui.item.value).draw();
            $("#clearSearchRiwayat").addClass('show-x');
            return false;
        }
    });
}

