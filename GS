// ==========================================
// 2. FUNGSI DATABASE (GET DATA MASTER)
// ==========================================
function getDataMaster() {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const fetch = (name, col, start) => {
      const sh = ss.getSheetByName(name);
      if (!sh || sh.getLastRow() < start) return [];
      return sh.getRange(start, 1, sh.getLastRow() - (start - 1), col).getDisplayValues();
    };
    return { 
      pegawai: fetch(SHEET_PEGAWAI, 4, 2),
      kegiatan: fetch(SHEET_KEGIATAN, 2, 2),
      pejabat: fetch(SHEET_PEJABAT, 3, 2),
      dasarHukum: fetch(SHEET_DASAR_HUKUM, 1, 1),
      riwayat: fetch(SHEET_RIWAYAT, 6, 2)
    };
  } catch (e) { throw new Error("Database Error: " + e.message); }
}

function getRiwayatData() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName(SHEET_RIWAYAT);
  if (sheet && sheet.getLastRow() > 1) {
    return sheet.getRange(2, 1, sheet.getLastRow() - 1, 6).getDisplayValues();
  }
  return[];
}


function hapusRiwayatById(id) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(SHEET_RIWAYAT);
  if (sheet) {
    const data = sheet.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] == id) {
        sheet.deleteRow(i + 1);
        return "Sukses";
      }
    }
  }
  throw new Error("Data Riwayat tidak ditemukan");
}

